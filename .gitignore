# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# supabase local dev — schema dump used to bootstrap smoke tests.
# Regenerate via `supabase db dump --schema public --linked -f ...`.
# Must NOT be committed (2600+ lines of prod snapshot).
supabase/migrations/00000000000000_*.sql
supabase/.temp/
supabase/.branches/
